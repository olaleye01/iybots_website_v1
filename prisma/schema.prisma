generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProjectBrief {
  id           String   @id @default(cuid())
  projectType  String
  businessGoal String
  tools        String[]
  otherTools   String?
  timeline     String
  name         String
  email        String
  companyName  String?
  projectNote  String?
  createdAt    DateTime @default(now())
}
